#!/bin/bash

# Git pre-commit hook installed by acme/code-quality-bundle
# This hook runs code quality checks on staged PHP files before commit

echo "🔍 Running code quality checks..."

# Get list of staged PHP files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep "\.php$" || true)

if [ -z "$STAGED_FILES" ]; then
    echo "✅ No PHP files to check"
    exit 0
fi

echo "Found $(echo "$STAGED_FILES" | wc -l) PHP file(s) to check"

# Convert staged files to array
FILES_ARRAY=($STAGED_FILES)

# Check if Symfony console is available
if [ ! -f "bin/console" ]; then
    echo "❌ bin/console not found. Cannot run quality checks."
    exit 1
fi

# Initialize exit code
EXIT_CODE=0

# Run PHPStan on staged files
echo ""
echo "Running PHPStan..."
php bin/console code-quality:phpstan --no-progress -- "${FILES_ARRAY[@]}"
PHPSTAN_EXIT=$?

if [ $PHPSTAN_EXIT -ne 0 ]; then
    echo "❌ PHPStan found issues"
    EXIT_CODE=1
else
    echo "✅ PHPStan passed"
fi

# Run PHPCS on staged files
echo ""
echo "Running PHP CodeSniffer..."
php bin/console code-quality:phpcs -- "${FILES_ARRAY[@]}"
PHPCS_EXIT=$?

if [ $PHPCS_EXIT -ne 0 ]; then
    echo "❌ PHPCS found issues"
    EXIT_CODE=1
else
    echo "✅ PHPCS passed"
fi

# Exit with failure if any check failed
if [ $EXIT_CODE -ne 0 ]; then
    echo ""
    echo "❌ Code quality checks failed. Commit aborted."
    echo ""
    echo "Fix the issues or use one of these options:"
    echo "  • Run 'php bin/console code-quality:check --fix' to auto-fix issues"
    echo "  • Use 'git commit --no-verify' to skip checks (not recommended)"
    exit 1
fi

echo ""
echo "✅ All code quality checks passed!"
exit 0
