{
    "name": "janit-org/code-quality-tools",
    "description": "Standardized code quality tooling for Symfony projects with PHPStan, PHP CodeSniffer, and Slevomat Coding Standard",
    "type": "symfony-bundle",
    "license": "MIT",
    "keywords": [
        "code-quality",
        "phpstan",
        "phpcs",
        "slevomat",
        "static-analysis",
        "symfony",
        "bundle"
    ],
    "authors": [
        {
            "name": "JanIT Development Team"
        }
    ],
    "require": {
        "php": "^8.3",
        "symfony/console": "^6.4|^7.4",
        "symfony/dependency-injection": "^6.4|^7.4",
        "symfony/http-kernel": "^6.4|^7.4",
        "symfony/config": "^6.4|^7.4",
        "symfony/process": "^6.4|^7.4",
        "symfony/finder": "^6.4|^7.4",
        "phpstan/phpstan": "^1.10",
        "phpstan/phpstan-symfony": "^1.3",
        "squizlabs/php_codesniffer": "^3.9",
        "slevomat/coding-standard": "^8.15"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "symfony/phpunit-bridge": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "Janit\\CodeQualityBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Janit\\CodeQualityBundle\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/code-quality"
    ],
    "extra": {
        "branch-alias": {
            "dev-main": "1.0-dev"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
